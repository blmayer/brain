{
  "id": "programming_languages/go/constructs/method_declaration",
  "kind": "SYNTACTIC_CONSTRUCT",
  "name": "Method Declaration",
  "description": "A function declaration attached to a type via a receiver.",
  "keywords": [
    "method",
    "receiver"
  ],
  "relations": {
    "hasReceiver": [
      {
        "target": "Receiver",
        "cardinality": "1"
      }
    ],
    "hasParent": [
      {
        "target": "programming_languages/go/constructs/function_declaration"
      }
    ]
  },
  "constraints": [
    "Must have exactly one receiver",
    "Receiver type must be defined in the same package (with some exceptions for interfaces)"
  ],
  "emitters": [
    {
      "id": "go-method-decl",
      "target": "go",
      "style": "standard",
      "template": "func ({{receiver}}) {{name}}{{signature}} {\n{{body}}\n}"
    }
  ]
}
