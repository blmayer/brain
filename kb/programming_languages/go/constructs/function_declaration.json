{
  "id": "programming_languages/go/constructs/function_declaration",
  "kind": "SYNTACTIC_CONSTRUCT",
  "name": "Function Declaration",
  "description": "A named function definition at package or local scope.",
  "keywords": [
    "function",
    "func",
    "define function",
    "method"
  ],
  "relations": {
    "hasParameter": [
      {
        "target": "Parameter",
        "cardinality": "0..*"
      }
    ],
    "hasReceiver": [
      {
        "target": "Receiver",
        "cardinality": "0..1"
      }
    ],
    "hasNamedReturn": [
      {
        "target": "Binding",
        "cardinality": "0..*"
      }
    ],
    "hasPositionalReturn": [
      {
        "target": "ReturnValue",
        "cardinality": "0..*"
      }
    ],
    "hasBody": [
      {
        "target": "programming_languages/go/constructs/block",
        "cardinality": "1"
      }
    ],
    "belongsToPackage": [
      {
        "target": "programming_languages/go/constructs/package",
        "cardinality": "0..1"
      }
    ],
    "hasParent": [
      {
        "target": "programming_languages/go/constructs/callable"
      },
      {
        "target": "Declaration"
      },
      {
        "target": "Statement"
      }
    ]
  },
  "constraints": [
    "Must have exactly one body (Block)",
    "Named returns and positional returns are mutually exclusive in a single declaration"
  ],
  "emitters": [
    {
      "id": "go-func-decl",
      "target": "go",
      "style": "standard",
      "template": "func {{name}}{{signature}} {\n{{body}}\n}"
    }
  ]
}
