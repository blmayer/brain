      {
        "target": "Statement",
        "cardinality": "0..1"
      }
    ],
    "hasCondition": [
      {
        "target": "Expression",
        "cardinality": "0..1"
      }
    ],
    "hasPost": [
      {
        "target": "Statement",
        "cardinality": "0..1"
      }
    ],
    "hasBody": [
      {
        "target": "Block",
        "cardinality": "1"
      }
    ]
  },
  "emitters": [
    {
      "id": "go-for",
      "target": "go",
      "template": "for {{init}}; {{condition}}; {{post}} {\n{{body}}\n}"
    }
  ]
