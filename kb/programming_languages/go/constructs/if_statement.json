{
  "id": "programming_languages/go/constructs/if_statement",
  "kind": "SYNTACTIC_CONSTRUCT",
  "name": "If Statement",
  "keywords": [
    "if",
    "else",
    "conditional",
    "condition"
  ],
  "relations": {
    "hasCondition": [
      {
        "target": "Expression",
        "cardinality": "1",
        "type": "boolean"
      }
    ],
    "hasThenBranch": [
      {
        "target": "programming_languages/go/constructs/block",
        "cardinality": "1"
      }
    ],
    "hasElseBranch": [
      {
        "target": "Statement",
        "cardinality": "0..1"
      }
    ],
    "hasParent": [
      {
        "target": "Statement"
      },
      {
        "target": "ControlFlowStatement"
      }
    ]
  },
  "emitters": [
    {
      "id": "go-if",
      "target": "go",
      "template": "if {{condition}} {\n{{then}}\n} {{else}}"
    }
  ]
}
