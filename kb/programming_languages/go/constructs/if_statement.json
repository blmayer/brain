{
  "id": "IfStatement",
  "kind": "SYNTACTIC_CONSTRUCT",
  "name": "If Statement",
  "parents": [
    "Statement",
    "ControlFlowStatement"
  ],
  "keywords": [
    "if",
    "else",
    "conditional",
    "condition"
  ],
  "relations": {
    "hasCondition": [
      {
        "target": "Expression",
        "cardinality": "1",
        "type": "boolean"
      }
    ],
    "hasThenBranch": [
      {
        "target": "Block",
        "cardinality": "1"
      }
    ],
    "hasElseBranch": [
      {
        "target": "Statement",
        "cardinality": "0..1"
      }
    ]
  },
  "emitters": [
    {
      "id": "go-if",
      "target": "go",
      "template": "if {{condition}} {\n{{then}}\n} {{else}}"
    }
  ]
}
