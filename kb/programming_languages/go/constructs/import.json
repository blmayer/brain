{
  "id": "programming_languages/go/constructs/import",
  "kind": "SYNTACTIC_CONSTRUCT",
  "name": "Import",
  "keywords": [
    "import",
    "use package"
  ],
  "relations": {
    "importsPackage": [
      {
        "target": "programming_languages/go/constructs/package",
        "cardinality": "1"
      }
    ],
    "alias": {
      "cardinality": "0..1",
      "description": "Optional import alias (including _ for blank imports)"
    },
    "hasParent": [
      {
        "target": "Declaration"
      }
    ]
  },
  "emitters": [
    {
      "id": "go-import",
      "target": "go",
      "template": "import {{alias}} \"{{path}}\""
    }
  ]
}
